<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Mitre | Nosotros</title>
    <link rel="shortcut icon" href="./assets/favicon.ico" type="image/x-icon">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="./css/styles.css">
</head>
<body>
    <header>
        <%- include('partials/_navbar') %>
    </header>

    <main class="page-background-main">
        <div class="content-container">
            
            <section class="intro-text">
                <span class="span-category-tag">Lounge Experience</span>
                <h1 class="title-header">The Mitre Bar</h1>
                <p>Donde la exclusividad encuentra su lugar</p>
            </section>

            <hr class="separator-gold">

            <section class="page-section">
                <div class="split-wrapper">
                    <div class="side-text">
                        <span class="span-category-tag">Nuestra Esencia</span>
                        <h2 class="title-header">Más que un bar, un club social</h2>
                        <p class="elegant-description">
                            En The Mitre, la exclusividad no es un lujo, es nuestro estándar. Creamos una atmósfera íntima con iluminación tenue, mobiliario de diseño y una curaduría musical diseñada para la charla.
                        </p>
                    </div>

                    <div class="side-visual">
                        <div class="swiper swiper-esencia">
                            <div class="swiper-wrapper">
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/img-ambiente-1.webp" alt="Ambiente 1"></div></div>
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/img-ambiente-2.webp" alt="Ambiente 2"></div></div>
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/img-ambiente-3.webp" alt="Ambiente 3"></div></div>
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/img-ambiente-4.webp" alt="Ambiente 4"></div></div>
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/img-ambiente-5.webp" alt="Ambiente 5"></div></div>
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/fondo_bienvenida.webp" alt="Ambiente 6"></div></div>
                            </div>
                            <div class="swiper-pagination"></div>
                        </div>
                    </div>
                </div>
            </section>

            <hr class="separator-gold">

            <section class="page-section">
                <div class="split-wrapper"> 
                    <div class="side-text">
                        <span class="span-category-tag">Eventos públicos y privados</span>
                        <h2 class="title-header">Un lugar exclusivo</h2>
                        <p class="elegant-description">
                            Lanzamientos, cenas corporativas o festejos íntimos.
                            Ponemos nuestro club a tu entera disposición.
                        </p>
                        <a href="https://wa.me/5491173568460" class="btn-cta capsule-btn">Consultar disponibilidad</a>
                    </div>

                    <div class="side-visual">
                        <div class="swiper swiper-eventos">
                            <div class="swiper-wrapper">
                                <div class="swiper-slide">
                                    <div class="rectangle-box">
                                        <video autoplay muted loop playsinline class="video-slide" poster="/assets/img-evento-preview.webp">
                                            <source src="/assets/dj.mp4" type="video/mp4">
                                        </video>
                                    </div>
                                </div>
                                <div class="swiper-slide">
                                    <div class="rectangle-box">
                                        <video autoplay muted loop playsinline class="video-slide" poster="/assets/img-barra.webp">
                                            <source src="/assets/salon.mp4" type="video/mp4">
                                        </video>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-pagination"></div>
                        </div>
                    </div>
                </div>
            </section>

            <hr class="separator-gold">

            <section class="page-section">
                <div class="split-wrapper">
                    <div class="side-text">
                        <span class="span-category-tag">Nuestra Carta</span>
                        <h2 class="title-header">Sabores con Identidad</h2>
                        <p class="elegant-description">
                            Desde cafetería artesanal y pastelería hasta una sofisticada propuesta de sushi nikkei y cocina de autor.
                        </p>
                        <a href="/nuestra-carta" class="btn-cta capsule-btn">VER CARTA</a>
                    </div>

                    <div class="side-visual">
                        <div class="swiper swiper-carta">
                            <div class="swiper-wrapper">
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/img-plato-1.webp" alt="Platos 1"></div></div>
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/img-plato-2.webp" alt="Platos 2"></div></div>
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/img-sugerencia.webp" alt="Platos 3"></div></div>
                                <div class="swiper-slide"><div class="rectangle-box"><img src="/assets/img-plato-3.webp" alt="Platos 4"></div></div>
                            </div>
                            <div class="swiper-pagination"></div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <%- include('partials/_footer') %>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="./js/script.js"></script>
</body>
</html>

